# Copy this to .env and fill in your values, then restart Docker
DATABASE_URL=postgresql://postgres:postgres@db:5432/stockdraft
NEXTAUTH_SECRET=changeme-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Your production domain (used for OG tags, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Gmail SMTP for OTP login emails
# 1. Enable 2-Step Verification at myaccount.google.com/security
# 2. Create an App Password at myaccount.google.com/apppasswords (select "Mail")
# 3. Paste the 16-character password (spaces OK) below
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
